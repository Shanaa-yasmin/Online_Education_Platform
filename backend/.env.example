# ── Django ───────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
FRONTEND_URL=http://localhost:5173

# ── PostgreSQL / Supabase ────────────────────────────────────────────────────
# Option A (preferred): single connection string from Supabase dashboard
#   Supabase → Project Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Option B: individual variables (used only if DATABASE_URL is not set)
# DB_NAME=postgres
# DB_USER=postgres.[project-ref]
# DB_PASSWORD=your-supabase-db-password
# DB_HOST=aws-0-[region].pooler.supabase.com
# DB_PORT=6543

# Set to 'true' to use Supabase's pgbouncer pooler (port 6543, recommended)
# Set to 'false' for the direct connection (port 5432)
USE_PGBOUNCER=true

# Connection lifetime in seconds (default 600).
# Set to 0 if using pgbouncer in transaction mode and experiencing issues.
CONN_MAX_AGE=600

# ── Stripe Test Mode ─────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Get this by running: stripe listen --forward-to localhost:8000/api/payments/checkout/stripe-webhook/
# OR from Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ── PayPal Sandbox ───────────────────────────────────────────────────────────
# Get these from https://developer.paypal.com/dashboard/applications/sandbox
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_SECRET=your-paypal-secret
PAYPAL_MODE=sandbox     # change to "live" for production

# ── Redis ─────────────────────────────────────────────────────────────────────
# Used by: Django cache backend (admin dashboard + reports caching)
#          Django Channels channel layer broker (WebSocket message routing)
#
# Local dev  — requires Docker Desktop:
#   docker run -d --name edupath-redis -p 6379:6379 redis:7-alpine
#   docker exec edupath-redis redis-cli ping   # should return PONG
#
# Production — use a managed Redis service; do NOT self-host on an ephemeral dyno.
#   Upstash:      rediss://:password@your-endpoint.upstash.io:6379/1
#   Redis Cloud:  redis://:password@redis-xxxxx.c1.us-east-1-2.ec2.cloud.redislabs.com:12345/1
#   Railway:      redis://default:password@containers-us-west-xxx.railway.app:6379/1
#
# Note: use rediss:// (double-s) for TLS-enabled managed instances.
REDIS_URL=redis://127.0.0.1:6379/1

# ── Elasticsearch ─────────────────────────────────────────────────────────────
# Full-text search, autocomplete, and faceted filtering for the course catalog.
#
# Local dev — requires Docker Desktop:
#   docker run -d --name edupath-es -p 9200:9200 -e "discovery.type=single-node" \
#     -e "xpack.security.enabled=false" elasticsearch:8.15.0
#   curl http://localhost:9200   # should return cluster info JSON
#
# Set ES_ENABLED=false to skip ES entirely and fall back to ORM search.
ES_ENABLED=true
ES_HOST=localhost
ES_PORT=9200
ES_SCHEME=http
# ES_API_KEY=            # Elastic Cloud API key (mutually exclusive with user/pass)
# ES_USER=elastic        # Basic auth user (self-hosted)
# ES_PASSWORD=changeme   # Basic auth password

# ── Cloudinary Media Storage ──────────────────────────────────────────────────
# Set USE_CLOUDINARY=true to upload course thumbnails and user avatars to Cloudinary.
USE_CLOUDINARY=false
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ── CORS & CSRF Origins ───────────────────────────────────────────────────────
# Comma-separated hosts allowed to run Python web server requests.
# Django CORS and CSRF headers will be configured automatically from these variables.
# E.g. ALLOWED_HOSTS=my-backend.onrender.com,localhost,127.0.0.1
ALLOWED_HOSTS=localhost,127.0.0.1
# E.g. CORS_ALLOWED_ORIGINS=https://my-frontend.vercel.app,http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173
# E.g. CSRF_TRUSTED_ORIGINS=https://my-frontend.vercel.app,https://my-backend.onrender.com
CSRF_TRUSTED_ORIGINS=http://localhost:5173

